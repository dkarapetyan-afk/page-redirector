{
    "manifest_version": 3,
    "name": "Page Redirector",
    "version": "1.18",
    "description": "Redirects certain pages to other pages automatically.",
    "permissions": [
        "storage",
        "webRequest",
        "webRequestBlocking",
        "tabs",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "background.js"
        ],
        "type": "module"
    },
    "icons": {
        "48": "icon-48.png",
        "96": "icon-96.png",
        "128": "icon-128.png"
    },
    "action": {
        "default_title": "Open Redirector Settings",
        "default_popup": "popup.html"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "redirector@antigravity.test",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}